# ============ 应用配置 ============
APP_NAME=模糊视觉辅助问答系统后端
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_PREFIX=/api/v1

# ============ 开发模式（不注册小程序时启用）============
# true: 跳过 wx.login，用 mock 登录；订阅消息降级为 WS 推送+日志
DEV_MODE=true
# mock 登录用：dev 模式下传任意 openid 自动建号
MOCK_OPENID_ELDERY=dev_elder_001
MOCK_OPENID_CHILD=dev_child_001

# ============ 微信小程序（生产用，dev 模式可留空）============
WX_APP_ID=
WX_APP_SECRET=

# ============ JWT ============
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ============ MySQL ============
# 本地测试用 root 无密码或自定义
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=ftraining_db
MYSQL_POOL_SIZE=10
MYSQL_MAX_OVERFLOW=20

# ============ Chroma 向量库 ============
# 本地文件模式
CHROMA_PERSIST_PATH=./data/chroma
CHROMA_COLLECTION_MEMORY=long_term_memory

# ============ 文件上传 ============
UPLOAD_DIR=./data/uploads
UPLOAD_URL_PREFIX=/files

# ============ 大模型 API（服务端集中管理）============
# 默认接口配置，dev 可填自己的 key
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=60

# ============ 审计日志 ============
AUDIT_RETAIN_DAYS=180

# ============ CORS ============
CORS_ORIGINS=*

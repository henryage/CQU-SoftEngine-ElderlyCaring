<view class="camera-preview">
  <camera 
    id="camera"
    device-position="{{devicePosition}}" 
    flash="{{flash}}" 
    binderror="onCameraError"
    class="camera"
  >
  </camera>
  
  <view class="camera-overlay" wx:if="{{showScanFrame}}">
    <view class="scan-frame">
      <view class="scan-line"></view>
    </view>
  </view>
  
  <view class="camera-controls">
    <view class="control-btn" bindtap="switchCamera">
      <text>切换</text>
    </view>
    
    <view class="capture-btn" bindtap="handleCapture">
      <view class="capture-inner"></view>
    </view>
    
    <view class="control-btn" bindtap="toggleFlash">
      <text>{{flash === 'on' ? '关灯' : '开灯'}}</text>
    </view>
  </view>
</view>
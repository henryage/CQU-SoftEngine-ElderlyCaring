.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  padding: 80rpx 30rpx 60rpx;
}

.header-content {
  display: flex;
  align-items: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar text {
  font-size: 80rpx;
}

.user-info {
  margin-left: 30rpx;
}

.nickname {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
  display: block;
}

.user-id {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 12rpx;
  display: block;
}

.content {
  padding: 30rpx;
}

.section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.token-card {
  background: #f9f9f9;
  border-radius: 16rpx;
  padding: 24rpx;
}

.token-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.token-label-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.token-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.token-type-badge {
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
}

.token-type-badge text {
  font-size: 24rpx;
  font-weight: bold;
}

.token-type-badge.mock {
  background: #FFF3E0;
}

.token-type-badge.mock text {
  color: #FF9800;
}

.token-type-badge.real {
  background: #E8F5E9;
}

.token-type-badge.real text {
  color: #4CAF50;
}

.token-type-badge.other {
  background: #ECEFF1;
}

.token-type-badge.other text {
  color: #607D8B;
}

.token-tip {
  margin-top: 20rpx;
  padding: 16rpx;
  background: #FFF9C4;
  border-radius: 12rpx;
}

.token-tip text {
  font-size: 26rpx;
  color: #8D6E63;
  line-height: 1.5;
}

.token-actions {
  display: flex;
  gap: 20rpx;
}

.token-action-btn {
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: 2rpx solid #e0e0e0;
}

.token-action-btn text {
  font-size: 26rpx;
  color: #666666;
}

.token-value {
  background: #333333;
  border-radius: 12rpx;
  padding: 24rpx;
  word-break: break-all;
}

.token-value text {
  font-size: 28rpx;
  color: #4CAF50;
  font-family: monospace;
  line-height: 1.6;
}

.add-btn {
  background: #E8F5E9;
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
}

.add-btn text {
  font-size: 30rpx;
  color: #4CAF50;
  font-weight: bold;
}

.child-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.child-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
}

.child-info {
  flex: 1;
}

.child-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.child-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.child-relation {
  font-size: 24rpx;
  color: #ffffff;
  background: #4CAF50;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.child-phone {
  font-size: 28rpx;
  color: #666666;
  margin-top: 8rpx;
  display: block;
}

.child-time {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
  display: block;
}

.child-actions {
  margin-left: 20rpx;
}

.unbind-btn {
  padding: 16rpx 32rpx;
  border: 3rpx solid #FF5252;
  border-radius: 32rpx;
}

.unbind-btn text {
  font-size: 28rpx;
  color: #FF5252;
  font-weight: bold;
}

.empty-state {
  text-align: center;
  padding: 60rpx 30rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-top: 20rpx;
  display: block;
}

.empty-hint {
  font-size: 28rpx;
  color: #999999;
  margin-top: 12rpx;
  display: block;
}

.menu-list {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 36rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 48rpx;
  color: #cccccc;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 680rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.modal-header text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  padding: 10rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 120rpx;
  padding: 0 30rpx;
  background: #f9f9f9;
  border-radius: 20rpx;
  font-size: 36rpx;
  box-sizing: border-box;
  border: 3rpx solid #e0e0e0;
}

.form-input:focus {
  border-color: #4CAF50;
}

.relation-options {
  display: flex;
  gap: 24rpx;
}

.relation-option {
  flex: 1;
  height: 100rpx;
  border-radius: 20rpx;
  background: #f9f9f9;
  border: 3rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.relation-option text {
  font-size: 32rpx;
  color: #666666;
}

.relation-option.selected {
  border-color: #4CAF50;
  background: #E8F5E9;
}

.relation-option.selected text {
  color: #4CAF50;
  font-weight: bold;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}

.modal-btn {
  flex: 1;
  height: 120rpx;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn text {
  font-size: 36rpx;
  font-weight: bold;
}

.modal-btn.cancel {
  background: #f0f0f0;
}

.modal-btn.cancel text {
  color: #666666;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
}

.modal-btn.confirm text {
  color: #ffffff;
}
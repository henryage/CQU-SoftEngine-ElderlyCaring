/* 页面基础样式 */
.page {
  min-height: 100vh;
  background-color: #000000;
  display: flex;
  flex-direction: column;
}

/* 摄像头背景 */
.camera-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.camera-bg.camera-disabled {
  display: none;
}

/* 主容器 */
.app-container {
  position: relative;
  z-index: 10;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部状态栏 */
.top-bar {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 60rpx 30rpx 20rpx;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.8), transparent);
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
}

.status-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.status-dot.online {
  background-color: #4CAF50;
  box-shadow: 0 0 16rpx #4CAF50;
  animation: pulse 2s ease-in-out infinite;
}

.status-dot.offline {
  background-color: #ff5252;
  box-shadow: 0 0 16rpx #ff5252;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 中央顶部控制按钮 */
.center-top-controls {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 10rpx 0 20rpx;
}

.control-btn-large {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.control-btn-large text {
  font-size: 52rpx;
}

/* 主交互区域 */
.main-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 30rpx;
}

/* AI状态指示 */
.ai-indicator {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.ai-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(76, 175, 80, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: breathe 3s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

.ai-avatar text {
  font-size: 56rpx;
}

.ai-status {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.typing-indicator {
  display: flex;
  gap: 10rpx;
}

.typing-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4CAF50;
  animation: typing 1.4s infinite ease-in-out both;
}

.typing-dot:nth-child(1) { animation-delay: -0.32s; }
.typing-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.ai-status-text {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
}

/* 消息容器 */
.message-container {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 20rpx;
}

.message-item {
  margin-bottom: 28rpx;
}

.message-item:last-child {
  margin-bottom: 0;
}

.message-bubble {
  border-radius: 28rpx;
  padding: 32rpx 40rpx;
  max-width: 85%;
}

.message-bubble.ai-bubble {
  background: rgba(76, 175, 80, 0.85);
  border-bottom-left-radius: 8rpx;
}

.message-bubble.user-bubble {
  background: rgba(76, 139, 255, 0.85);
  border-bottom-right-radius: 8rpx;
  margin-left: auto;
}

.message-text {
  color: #ffffff;
  font-size: 44rpx;
  line-height: 1.7;
  display: block;
  font-weight: 500;
}

.message-time {
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
  margin-top: 14rpx;
  display: block;
  text-align: right;
}

/* 底部操作区域 */
.bottom-panel {
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(0, 0, 0, 0.95), rgba(0, 0, 0, 0.8), transparent);
}

/* 一键操作区 - 超大按钮 */
.action-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  height: 180rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.action-btn:active {
  transform: scale(0.96);
}

.action-btn.primary-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  box-shadow: 0 8rpx 32rpx rgba(76, 175, 80, 0.4);
}

.action-btn.secondary-btn {
  background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
  box-shadow: 0 8rpx 32rpx rgba(33, 150, 243, 0.4);
}

.action-icon {
  font-size: 72rpx;
}

.action-text {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: bold;
}

/* 功能按钮区 */
.function-row {
  display: flex;
  gap: 16rpx;
}

.function-btn {
  flex: 1;
  height: 130rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.function-btn:active {
  transform: scale(0.96);
}

.func-icon {
  font-size: 44rpx;
}

.func-text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

.function-btn.emergency-btn {
  background: linear-gradient(135deg, #ff5252 0%, #d32f2f 100%);
}

.function-btn.emergency-btn .func-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}

.function-btn.child-btn {
  background: rgba(255, 152, 0, 0.85);
}

/* 模态框 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 680rpx;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
}

.modal-header {
  padding: 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-header text {
  font-size: 44rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  font-size: 52rpx;
  color: #999999;
  padding: 16rpx;
}

.modal-textarea {
  width: 100%;
  height: 400rpx;
  padding: 40rpx;
  font-size: 40rpx;
  box-sizing: border-box;
}

.modal-footer {
  padding: 30rpx 40rpx;
  display: flex;
  gap: 30rpx;
}

.modal-btn {
  flex: 1;
  height: 130rpx;
  border-radius: 65rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn text {
  font-size: 40rpx;
  font-weight: bold;
}

.modal-btn.cancel {
  background: #f5f5f5;
}

.modal-btn.cancel text {
  color: #666666;
}

.modal-btn.confirm {
  background: #4CAF50;
}

.modal-btn.confirm text {
  color: #ffffff;
}

.modal-btn.child-confirm {
  background: #ff9800;
}

/* 紧急呼叫模态框 */
.emergency-modal {
  text-align: center;
  padding: 60rpx;
}

.emergency-icon-large {
  font-size: 180rpx;
  margin-bottom: 30rpx;
}

.emergency-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #ff5252;
  display: block;
}

.emergency-desc {
  font-size: 36rpx;
  color: #666666;
  margin-top: 20rpx;
  display: block;
}

.emergency-actions {
  margin-top: 50rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.emergency-call-btn {
  height: 140rpx;
  background: #ff5252;
  border-radius: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emergency-call-btn text {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: bold;
}

.emergency-cancel-btn {
  height: 110rpx;
  background: #f5f5f5;
  border-radius: 55rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.emergency-cancel-btn text {
  color: #666666;
  font-size: 36rpx;
}

/* 联系子女模态框 */
.child-modal .modal-textarea {
  height: 300rpx;
}

/* 提示消息 */
.toast-notification {
  position: fixed;
  top: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.85);
  border-radius: 28rpx;
  padding: 30rpx 40rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  z-index: 2000;
  animation: toast-slide-in 0.3s ease-out;
}

@keyframes toast-slide-in {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

.toast-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toast-icon {
  font-size: 48rpx;
}

.toast-text {
  color: #ffffff;
  font-size: 40rpx;
  max-width: 500rpx;
}
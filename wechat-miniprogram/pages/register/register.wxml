<view class="page">
  <view class="header">
    <text class="title">注册账号</text>
    <text class="subtitle">模糊视觉辅助问答系统</text>
  </view>

  <view class="step-indicator">
    <view class="step {{currentStep === 1 ? 'active' : ''}}">
      <text class="step-num">1</text>
      <text class="step-text">老人信息</text>
    </view>
    <view class="step-line {{currentStep > 1 ? 'active' : ''}}"></view>
    <view class="step {{currentStep === 2 ? 'active' : ''}}">
      <text class="step-num">2</text>
      <text class="step-text">子女捆绑</text>
    </view>
  </view>

  <view class="form-section" wx:if="{{currentStep === 1}}">
    <view class="form-group">
      <text class="form-label">老人姓名</text>
      <input 
        class="form-input" 
        placeholder="请输入老人姓名"
        value="{{userName}}"
        bindinput="onUserNameInput"
      />
    </view>
    
    <view class="form-group">
      <text class="form-label">联系电话</text>
      <input 
        class="form-input" 
        placeholder="请输入联系电话"
        value="{{phone}}"
        type="number"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="form-group">
      <text class="form-label">设置密码</text>
      <input 
        class="form-input" 
        placeholder="请设置登录密码"
        value="{{password}}"
        type="password"
        bindinput="onPasswordInput"
      />
    </view>

    <view class="form-group">
      <text class="form-label">确认密码</text>
      <input 
        class="form-input" 
        placeholder="请再次输入密码"
        value="{{confirmPassword}}"
        type="password"
        bindinput="onConfirmPasswordInput"
      />
    </view>

    <view class="btn-large primary" bindtap="nextStep">
      <text>下一步</text>
    </view>
  </view>

  <view class="form-section" wx:if="{{currentStep === 2}}">
    <view class="tip-card">
      <text class="tip-icon">💡</text>
      <text class="tip-text">请填写子女信息，完成后将与老人账号绑定</text>
    </view>

    <view class="form-group">
      <text class="form-label">子女姓名</text>
      <input 
        class="form-input" 
        placeholder="请输入子女姓名"
        value="{{childName}}"
        bindinput="onChildNameInput"
      />
    </view>
    
    <view class="form-group">
      <text class="form-label">子女电话</text>
      <input 
        class="form-input" 
        placeholder="请输入子女联系电话"
        value="{{childPhone}}"
        type="number"
        bindinput="onChildPhoneInput"
      />
    </view>

    <view class="form-group">
      <text class="form-label">关系</text>
      <view class="relation-options">
        <view 
          class="relation-option {{relation === '子女' ? 'selected' : ''}}" 
          bindtap="selectRelation"
          data-value="子女"
        >
          <text>子女</text>
        </view>
        <view 
          class="relation-option {{relation === '亲属' ? 'selected' : ''}}" 
          bindtap="selectRelation"
          data-value="亲属"
        >
          <text>亲属</text>
        </view>
        <view 
          class="relation-option {{relation === '医生' ? 'selected' : ''}}" 
          bindtap="selectRelation"
          data-value="医生"
        >
          <text>医生</text>
        </view>
      </view>
    </view>

    <view class="btn-large primary" bindtap="submitRegister">
      <text>完成注册</text>
    </view>

    <view class="btn-large secondary" bindtap="prevStep">
      <text>上一步</text>
    </view>
  </view>
</view>
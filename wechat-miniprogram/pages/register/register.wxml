<view class="page">
  <view class="header">
    <text class="title">登录</text>
    <text class="subtitle">模糊视觉辅助问答系统</text>
  </view>

  <view class="form-section">
    <view class="btn-large primary" bindtap="handleLogin">
      <text>微信一键登录</text>
    </view>

    <view class="skip-btn" bindtap="handleSkipLogin">
      <text>跳过登录，直接使用</text>
    </view>

    <view class="debug-btn" bindtap="handleDebug">
      <text>网络诊断</text>
    </view>
  </view>
</view>
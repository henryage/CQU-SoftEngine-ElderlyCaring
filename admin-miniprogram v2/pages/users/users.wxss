/* admin-miniprogram/pages/users/users.wxss */

/* Modal 样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  max-height: 70vh;
  background: #ffffff;
  border-radius: 16rpx;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1px solid #f0f0f0;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.modal-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 32rpx 32rpx;
}

.modal-loading {
  text-align: center;
  padding: 48rpx 0;
  color: #999;
  font-size: 26rpx;
}

.modal-empty {
  text-align: center;
  padding: 48rpx 0;
  color: #999;
  font-size: 26rpx;
}

.modal-list-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid #f5f5f5;
}

.modal-list-item:last-child {
  border-bottom: none;
}

.modal-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.modal-info {
  flex: 1;
  min-width: 0;
}

.modal-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
}

.modal-detail {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

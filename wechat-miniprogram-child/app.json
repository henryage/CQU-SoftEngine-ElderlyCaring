{
  "lazyCodeLoading": "requiredComponents",
  "pages": [
    "pages/index/index",
    "pages/alert/alert",
    "pages/profile/profile"
  ],
  "subPackages": [
    {
      "root": "subpkg-health",
      "name": "health",
      "pages": [
        "pages/health/health",
        "pages/medication/medication",
        "pages/trace/trace"
      ]
    },
    {
      "root": "subpkg-care",
      "name": "care",
      "pages": [
        "pages/message/message",
        "pages/greeting/greeting",
        "pages/history/history"
      ]
    },
    {
      "root": "subpkg-manage",
      "name": "manage",
      "pages": [
        "pages/bind/bind",
        "pages/settings/settings",
        "pages/knowledge/knowledge"
      ]
    }
  ],
  "preloadRule": {
    "pages/index/index": {
      "network": "all",
      "packages": ["health"]
    }
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#4A90D9",
    "borderStyle": "white",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "images/tab-home.png",
        "selectedIconPath": "images/tab-home-active.png"
      },
      {
        "pagePath": "pages/alert/alert",
        "text": "预警",
        "iconPath": "images/tab-alert.png",
        "selectedIconPath": "images/tab-alert-active.png"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的",
        "iconPath": "images/tab-profile.png",
        "selectedIconPath": "images/tab-profile-active.png"
      }
    ]
  },
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#4A90D9",
    "navigationBarTitleText": "孝心守护",
    "navigationBarTextStyle": "white",
    "backgroundColor": "#f5f5f5"
  },
  "permission": {
    "scope.userLocation": {
      "desc": "需要获取您的位置信息用于查看老人位置"
    }
  },
  "sitemapLocation": "sitemap.json"
}

<view class="container">
  <!-- 预警统计卡片 -->
  <view class="page-header">
    <view class="page-header-title">预警中心</view>
    <view class="page-header-sub">实时守护老人安全，异常情况及时知晓</view>
  </view>

  <!-- 预警类型统计 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">预警概览</view>
    <view class="func-grid">
      <view class="func-item">
        <view class="func-icon" style="background-color:#FFF1F0;">🚨</view>
        <view class="func-label">未活动预警</view>
      </view>
      <view class="func-item">
        <view class="func-icon" style="background-color:#FFF7E6;">💊</view>
        <view class="func-label">用药异常</view>
      </view>
      <view class="func-item">
        <view class="func-icon" style="background-color:#F6FFED;">📋</view>
        <view class="func-label">饮食异常</view>
      </view>
    </view>
  </view>

  <!-- 预警列表 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">预警记录</view>
    <view class="empty-state" style="padding:40rpx;">
      <view class="text-sm text-gray">暂无预警记录</view>
    </view>
  </view>
</view>

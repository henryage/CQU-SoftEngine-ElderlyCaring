<view class="container">
  <view class="page-header">
    <view class="page-header-title">个人中心</view>
    <view class="page-header-sub">{{nickname}}</view>
  </view>

  <!-- 用户信息卡片 -->
  <view class="card">
    <view class="list-item-left" style="margin-bottom:20rpx;">
      <view class="list-item-icon icon-profile">我</view>
      <view>
        <view class="text-lg text-bold">{{nickname}}</view>
        <view class="text-sm text-gray">ID: {{childId}}</view>
      </view>
    </view>
  </view>

  <!-- 手机号绑定 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">手机号绑定</view>
    <view class="input-row mb-16">
      <view class="text-sm text-gray mb-8">手机号</view>
      <input class="bind-input" type="number" maxlength="11" placeholder="请输入11位手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="input-row mb-16">
      <view class="text-sm text-gray mb-8">姓名（选填）</view>
      <input class="bind-input" placeholder="真实姓名" value="{{bindName}}" bindinput="onNameInput" />
    </view>
    <view class="input-row mb-20">
      <view class="text-sm text-gray mb-8">关系（选填）</view>
      <input class="bind-input" placeholder="如：子女" value="{{bindRelation}}" bindinput="onRelationInput" />
    </view>
    <view class="btn-primary" bindtap="doBindPhone" loading="{{loading}}">保存</view>
  </view>

  <!-- 功能入口 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">快捷功能</view>
    <view class="list-item" bindtap="goToAlerts">
      <view class="list-item-left">
        <view class="list-item-icon icon-danger">警</view>
        <view class="text-md">预警中心</view>
      </view>
      <view class="list-item-arrow">&gt;</view>
    </view>
    <view class="list-item" bindtap="goToBind">
      <view class="list-item-left">
        <view class="list-item-icon icon-bind">绑</view>
        <view class="text-md">绑定管理</view>
      </view>
      <view class="list-item-arrow">&gt;</view>
    </view>
  </view>

  <!-- 切换账号 -->
  <view class="card text-center">
    <view class="btn-secondary" bindtap="doSwitchAccount">切换账号</view>
  </view>
</view>

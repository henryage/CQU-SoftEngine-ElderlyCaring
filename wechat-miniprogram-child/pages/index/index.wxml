<view class="container">
  <!-- 头部标题 -->
  <view class="page-header">
    <view class="page-header-title">孝心守护</view>
    <view class="page-header-sub">守护家人健康</view>
  </view>

  <!-- 当前子女 ID -->
  <view class="card" style="padding:20rpx 30rpx;font-size:24rpx;color:#999;">
    child_id: {{childId}}<text style="margin-left:16rpx;color:#bbb;">（后端 child 路由开发中，功能即将上线）</text>
  </view>

  <!-- 功能入口网格 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">功能服务</view>
    <view class="func-grid">
      <view class="func-item" bindtap="goToHealth">
        <view class="func-icon icon-health">心</view>
        <view class="func-label">健康看板</view>
      </view>
      <view class="func-item" bindtap="goToMedication">
        <view class="func-icon icon-med">药</view>
        <view class="func-label">用药提醒</view>
      </view>

      <view class="func-item" bindtap="goToHistory">
        <view class="func-icon icon-history">答</view>
        <view class="func-label">问答记录</view>
      </view>
      <view class="func-item" bindtap="goToMessage">
        <view class="func-icon icon-msg">聊</view>
        <view class="func-label">亲情通信</view>
      </view>
      <view class="func-item" bindtap="goToGreeting">
        <view class="func-icon icon-greet">候</view>
        <view class="func-label">定时问候</view>
      </view>
      <view class="func-item" bindtap="goToSettings">
        <view class="func-icon icon-set">设</view>
        <view class="func-label">远程设置</view>
      </view>
      <view class="func-item" bindtap="goToKnowledge">
        <view class="func-icon icon-know">库</view>
        <view class="func-label">健康画像</view>
      </view>
      <view class="func-item" bindtap="goToBind">
        <view class="func-icon icon-bind">绑</view>
        <view class="func-label">绑定管理</view>
      </view>
    </view>
  </view>
</view>

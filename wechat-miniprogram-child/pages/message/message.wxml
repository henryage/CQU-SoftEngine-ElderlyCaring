<view class="container">
  <view class="page-header">
    <view class="page-header-title">亲情通信</view>
    <view class="page-header-sub">对应数据库: communication_log · 与老人文字/语音互动</view>
  </view>

  <!-- 发送消息区 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">发送消息</view>
    <textarea style="width:100%;height:120rpx;border:2rpx solid #e0e0e0;border-radius:12rpx;padding:16rpx;font-size:28rpx;box-sizing:border-box;" placeholder="请输入要给老人发送的文字..." />
    <view class="btn-primary mt-20">发送文字</view>
    <view class="btn-secondary mt-20">🎤 发送语音</view>
  </view>

  <!-- 通信记录 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">通信记录</view>
    <view class="empty-state" style="padding:40rpx;">
      <view class="text-sm text-gray">暂无通信记录</view>
    </view>
  </view>
</view>

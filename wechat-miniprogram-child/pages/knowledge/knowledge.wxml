<view class="container">
  <view class="page-header">
    <view class="page-header-title">知识库管理</view>
    <view class="page-header-sub">对应数据库: long_term_memory · RAG知识库与合规词管理</view>
  </view>

  <!-- 知识条目管理 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">知识条目</view>
    <view class="flex-between mb-20">
      <view class="text-sm text-gray">管理AI可检索的知识条目</view>
      <view class="btn-primary" style="padding:12rpx 24rpx;font-size:24rpx;margin-top:0;">+ 添加</view>
    </view>
    <view class="empty-state" style="padding:40rpx;">
      <view class="text-sm text-gray">暂无自定义知识条目</view>
    </view>
  </view>

  <!-- 敏感词拦截 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">敏感词拦截规则</view>
    <view class="flex-between mb-20">
      <view class="text-sm text-gray">管理用药敏感词与合规拦截规则</view>
      <view class="btn-primary" style="padding:12rpx 24rpx;font-size:24rpx;margin-top:0;">+ 添加</view>
    </view>
    <view class="empty-state" style="padding:40rpx;">
      <view class="text-sm text-gray">暂无自定义规则</view>
    </view>
  </view>

  <!-- 提示词模板 -->
  <view class="card">
    <view class="list-item" bindtap="noop">
      <view class="list-item-left">
        <view class="list-item-icon" style="background-color:#F0F5FF;">📄</view>
        <view class="text-md">系统提示词</view>
      </view>
      <view class="list-item-arrow">></view>
    </view>
    <view class="list-item" bindtap="noop">
      <view class="list-item-left">
        <view class="list-item-icon" style="background-color:#FFF7E6;">📋</view>
        <view class="text-md">合规知识包</view>
      </view>
      <view class="list-item-arrow">></view>
    </view>
  </view>
</view>

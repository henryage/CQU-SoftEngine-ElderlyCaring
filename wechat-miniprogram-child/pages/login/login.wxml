<view class="container">
  <view class="login-wrapper">
    <!-- Logo 区域 -->
    <view class="login-header">
      <view class="login-avatar">
        <text>孝</text>
      </view>
      <view class="login-title">孝心守护</view>
      <view class="login-sub">子女端</view>
    </view>

    <!-- 微信登录按钮 -->
    <button class="wx-login-btn" bindtap="doWxLogin" loading="{{loading}}" disabled="{{loading}}">
      <view class="wx-btn-content">
        <text class="wx-btn-text">{{loading ? '登录中...' : '微信一键登录'}}</text>
      </view>
    </button>

    <view wx:if="{{error}}" class="text-sm text-danger text-center" style="margin-top:24rpx;">{{error}}</view>

    <view class="text-xs text-gray text-center" style="margin-top:60rpx;">
      首次登录自动创建账号
    </view>
  </view>
</view>

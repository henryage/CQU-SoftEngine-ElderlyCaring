.login-wrapper {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  min-height: 80vh; padding: 40rpx;
}

.login-header {
  display: flex; flex-direction: column; align-items: center; margin-bottom: 80rpx;
}

.login-avatar {
  width: 160rpx; height: 160rpx; border-radius: 80rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #fff; font-size: 64rpx; font-weight: bold;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 12rpx 40rpx rgba(7, 193, 96, 0.35);
}

.login-title {
  font-size: 44rpx; font-weight: bold; color: #333; margin-bottom: 12rpx;
}

.login-sub {
  font-size: 28rpx; color: #999;
  background: #f0f0f0; padding: 4rpx 24rpx; border-radius: 20rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #4A90D9;
  border-radius: 48rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  margin-top: 40rpx;
}

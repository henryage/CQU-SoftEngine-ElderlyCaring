<view class="container">
  <view class="page-header">
    <view class="page-header-title">远程设置</view>
    <view class="page-header-sub">为老人配置参数</view>
  </view>

  <!-- 老人选择器 -->
  <view class="card" wx:if="{{bindedUsers.length > 0}}">
    <view class="text-sm text-gray mb-10">选择老人</view>
    <picker mode="selector" range="{{bindedUsers}}" range-key="nickname" bindchange="onElderSelect">
      <view class="elder-picker">
        <text wx:if="{{selectedNickname}}">{{selectedNickname}} (ID: {{selectedUserId}})</text>
        <text wx:else class="text-gray">请选择已绑定的老人</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>
  <view class="card text-center" wx:elif="{{bindedUsers.length === 0}}">
    <view class="text-sm text-gray">暂无绑定老人，请先到「绑定」页绑定</view>
  </view>

  <!-- 配置表单 -->
  <view class="card" wx:if="{{selectedUserId}}">
    <view class="text-lg text-bold mb-20">{{selectedNickname}} 的配置</view>
    <view class="list-item">
      <view class="text-md">字体大小</view>
      <picker mode="selector" range="{{fontSizes}}" bindchange="onFontChange">
        <view class="text-sm" style="color:#4A90D9;">{{settings.font_size || 'normal'}} ▼</view>
      </picker>
    </view>
    <view class="list-item">
      <view class="text-md">语音播报</view>
      <switch checked="{{settings.voice_enabled}}" bindchange="onVoiceToggle" />
    </view>
    <view class="list-item">
      <view class="text-md">简化模式</view>
      <switch checked="{{settings.simplified_mode}}" bindchange="onSimpleToggle" />
    </view>
    <view class="btn-primary" bindtap="doSave" disabled="{{saving}}">{{saving ? '保存中...' : '下发配置'}}</view>
  </view>

  <!-- 变更历史 -->
  <view class="card" wx:if="{{changes.length > 0}}">
    <view class="text-lg text-bold mb-20">变更历史</view>
    <view class="list-item" wx:for="{{changes}}" wx:key="change_id">
      <view class="text-sm">{{item.setting_key}}: {{item.old_value || '空'}} → {{item.new_value}}</view>
      <view class="text-xs text-gray">{{item.change_time}}</view>
    </view>
  </view>

</view>

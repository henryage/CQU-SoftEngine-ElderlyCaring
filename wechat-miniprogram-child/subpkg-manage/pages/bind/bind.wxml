<view class="container with-bottom-nav">
  <!-- 绑定表单 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">绑定老人账号</view>
    <view class="text-sm text-gray mb-20" style="line-height:1.6;">
      当前 child_id：<text wx:if="{{childId}}">{{childId}}</text><text wx:else>未登录</text>
    </view>
    <view class="text-sm" style="color:#E6A23C;background:#FDF6EC;padding:20rpx;border-radius:8rpx;margin-bottom:20rpx;line-height:1.6;">
      绑定功能依赖后端 child.py 路由（/api/v1/child/bind 等），该路由尚未实现。
      UserChildRelation 数据模型已定义，待后端开发完成后即可使用。
    </view>

    <view class="input-row mb-20">
      <view class="text-sm text-gray mb-10">老人 user_id</view>
      <input class="bind-input" type="number" placeholder="请输入 user.user_id" />
      <view class="text-sm text-gray" style="font-size:20rpx;margin-top:6rpx;">
        user 表主键（对应 user_child_relation.user_id）
      </view>
    </view>

    <view class="btn-primary btn-disabled" bindtap="doBind">确认绑定（待后端实现）</view>
  </view>

  <!-- 数据关系说明 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">数据关系说明</view>
    <view class="text-sm text-gray mb-10">
      绑定操作向 user_child_relation 表写入记录：
    </view>
    <view class="text-sm text-gray" style="background:#F5F5F5;padding:16rpx;border-radius:8rpx;font-family:monospace;line-height:1.8;">
      user_id（老人ID） → user.user_id<text style="opacity:0.4;">（必填）</text>
      child_id（子女ID） → child_user.child_id<text style="opacity:0.4;">（自动获取）</text>
      relation（关系） → "子女/配偶/父母/...）
      is_primary（主联系人） → 0 或 1
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="bottom-nav">
    <view class="bottom-nav-item" bindtap="goBack">
      <view class="bottom-nav-icon">&#9750;</view>
      <view>首页</view>
    </view>
    <view class="bottom-nav-item active">
      <view class="bottom-nav-icon">&#128279;</view>
      <view>绑定</view>
    </view>
    <view class="bottom-nav-item" bindtap="goToSettings">
      <view class="bottom-nav-icon">&#9881;</view>
      <view>设置</view>
    </view>
  </view>
</view>

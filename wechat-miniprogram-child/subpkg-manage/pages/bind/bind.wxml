<view class="container">
  <!-- 绑定表单 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">绑定老人账号</view>
    <view class="text-sm text-gray mb-20" style="line-height:1.6;">
      当前 child_id：<text wx:if="{{childId}}">{{childId}}</text><text wx:else>未登录</text>
    </view>

    <view class="input-row mb-20">
      <view class="text-sm text-gray mb-10">邀请码（6位数字）</view>
      <input class="bind-input" type="number" maxlength="6" placeholder="请输入老人端展示的6位邀请码" value="{{bindCode}}" bindinput="onCodeInput" />
    </view>

    <view class="input-row mb-20">
      <view class="text-sm text-gray mb-10">关系</view>
      <input class="bind-input" placeholder="如：子女、亲属、医生" value="{{bindRelation}}" bindinput="onRelationInput" />
    </view>

    <view class="btn-primary" bindtap="doBind">确认绑定</view>
  </view>

  <!-- 已绑定列表 -->
  <view class="card">
    <view class="text-lg text-bold mb-20">已绑定的老人</view>
    <block wx:if="{{bindedUsers.length > 0}}">
      <view class="binded-item" wx:for="{{bindedUsers}}" wx:key="user_id">
        <view class="binded-info">
          <view class="text-md text-bold">{{item.nickname || '老人' + item.user_id}}</view>
          <view class="text-sm text-gray">user_id: {{item.user_id}} | 关系: {{item.relation}}</view>
          <view class="text-sm" style="color:{{item.is_online ? '#07C160' : '#999'}}">
            {{item.is_online ? '● 在线' : '○ 离线'}}
            | 未读预警: {{item.unread_alerts || 0}}
            | 今日问答: {{item.today_qa_count || 0}}
          </view>
        </view>
        <view class="binded-action">
          <view class="btn-danger-sm" data-uid="{{item.user_id}}" data-nickname="{{item.nickname}}" bindtap="doUnbind">解绑</view>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="text-sm text-gray text-center">暂无绑定，请输入邀请码进行绑定</view>
    </block>
  </view>

</view>

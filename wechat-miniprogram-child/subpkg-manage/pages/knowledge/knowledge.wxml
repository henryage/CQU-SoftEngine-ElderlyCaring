<view class="container">
  <view class="page-header">
    <view class="page-header-title">健康画像</view>
    <view class="page-header-sub">长期记忆与知识库</view>
  </view>

  <!-- 老人选择器 -->
  <view class="card" wx:if="{{bindedUsers.length > 0}}">
    <view class="text-sm text-gray mb-10">选择老人</view>
    <picker mode="selector" range="{{bindedUsers}}" range-key="nickname" bindchange="onElderSelect">
      <view class="elder-picker">
        <text wx:if="{{selectedNickname}}">{{selectedNickname}} (ID: {{selectedUserId}})</text>
        <text wx:else class="text-gray">请选择已绑定的老人</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>
  <view class="card text-center" wx:elif="{{bindedUsers.length === 0}}">
    <view class="text-sm text-gray">暂无绑定老人，请先到「绑定」页绑定</view>
  </view>

  <!-- 搜索 -->
  <view class="card" wx:if="{{selectedUserId}}">
    <view class="flex-between mb-16">
      <input class="bind-input" style="flex:1;margin-right:16rpx;" placeholder="搜索记忆内容..." value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="doSearch" />
      <view class="btn-primary" style="width:120rpx;text-align:center;" bindtap="doSearch">搜索</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading"><view class="loading-text">加载中...</view></view>

  <view wx:elif="{{selectedUserId}}">
    <view wx:if="{{memories.length === 0}}" class="card">
      <view class="empty-state" style="padding:40rpx;">
        <view class="text-sm text-gray">{{keyword ? '未搜索到匹配记忆' : '暂无记忆条目'}}</view>
      </view>
    </view>

    <view wx:for="{{memories}}" wx:key="memory_id" class="card" bindtap="openDetail" data-id="{{item.memory_id}}">
      <view class="flex-between mb-10">
        <view class="text-lg text-bold" style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
          {{item.summary || item.content}}
        </view>
        <view wx:if="{{item.memory_type}}" class="tag tag-info">{{item.memory_type}}</view>
        <view wx:if="{{item.importance}}" class="text-sm" style="margin-left:8rpx;">
          {{item.importanceStars || ''}}
        </view>
      </view>
      <view class="text-sm text-gray mb-10" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
        {{item.content}}
      </view>
      <view class="flex-between">
        <view class="text-sm text-gray" style="font-size:20rpx;">来源: {{item.source}} · {{item.created_at}}</view>
        <view class="flex" catchtap="stopProp">
          <view class="btn-secondary" style="padding:4rpx 12rpx;font-size:20rpx;margin-right:8rpx;" catchtap="adjustImportance" data-id="{{item.memory_id}}" data-importance="{{item.importance}}">★</view>
          <view class="btn-secondary" style="padding:4rpx 16rpx;font-size:20rpx;" catchtap="doDelete" data-id="{{item.memory_id}}" data-summary="{{item.summary || item.content}}">删除</view>
        </view>
      </view>
    </view>

    <view class="card text-center">
      <view class="btn-primary" bindtap="showAddModal">+ 新增记忆条目</view>
    </view>
  </view>

  <!-- 添加弹窗 -->
  <view wx:if="{{showAddModal}}" class="modal">
    <view class="modal-content">
      <view class="text-lg text-bold mb-20">新增记忆条目</view>
      <view class="text-sm text-gray mb-10">类型</view>
      <input class="bind-input" style="margin-bottom:16rpx;" type="text" placeholder="用药 / 健康 / 偏好 / 医嘱 / 通用" value="{{newMemoryType}}" bindinput="onTypeInput" />
      <view class="text-sm text-gray mb-10">内容</view>
      <textarea class="bind-input" style="margin-bottom:16rpx;height:160rpx;" placeholder="请输入记忆内容" value="{{newContent}}" bindinput="onContentInput" maxlength="5000" />
      <view class="text-sm text-gray mb-10">重要度 (1-5)</view>
      <input class="bind-input" style="margin-bottom:16rpx;" type="number" placeholder="1-5，5最重要" value="{{newImportance}}" bindinput="onImportanceInput" />
      <view class="flex-between">
        <view class="btn-secondary" bindtap="hideAddModal">取消</view>
        <view class="btn-primary" bindtap="doCreate">确认添加</view>
      </view>
    </view>
  </view>

  <!-- 详情/编辑弹窗 -->
  <view wx:if="{{showDetailModal}}" class="modal">
    <view class="modal-content">
      <view class="text-lg text-bold mb-20">记忆详情</view>
      <view class="text-sm text-gray mb-10">类型</view>
      <input class="bind-input" style="margin-bottom:16rpx;" type="text" value="{{editMemoryType}}" bindinput="onEditTypeInput" />
      <view class="text-sm text-gray mb-10">内容</view>
      <textarea class="bind-input" style="margin-bottom:16rpx;height:160rpx;" value="{{editContent}}" bindinput="onEditContentInput" maxlength="5000" />
      <view class="text-sm text-gray mb-10">重要度 (1-5)</view>
      <input class="bind-input" style="margin-bottom:16rpx;" type="number" value="{{editImportance}}" bindinput="onEditImportanceInput" />
      <view class="flex-between">
        <view class="btn-secondary" bindtap="hideDetailModal">取消</view>
        <view class="btn-primary" bindtap="doUpdate">保存修改</view>
      </view>
    </view>
  </view>

</view>

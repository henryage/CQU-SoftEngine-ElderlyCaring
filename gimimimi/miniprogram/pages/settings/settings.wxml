<view class="page-container">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-back" bindtap="onGoBack">‹ 返回</view>
      <view class="nav-title">设置</view>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <view class="settings-list">
    <view class="setting-item" bindtap="onEditNickname">
      <view class="setting-label">修改昵称</view>
      <view class="setting-control-row">
        <view class="setting-value">{{nickname || '未设置'}}</view>
        <view class="setting-arrow">›</view>
      </view>
    </view>

    <view class="setting-item" bindtap="onGenerateBindCode">
      <view class="setting-label">绑定子女</view>
      <view class="setting-control-row">
        <view class="setting-value">获取验证码</view>
        <view class="setting-arrow">›</view>
      </view>
    </view>

    <view class="setting-item">
      <view class="setting-label">字体大小</view>
      <view class="setting-control">
        <view class="size-btn {{fontSize === 'normal' ? 'active' : ''}}" bindtap="onSetFontSize" data-size="normal">标准</view>
        <view class="size-btn {{fontSize === 'large' ? 'active' : ''}}" bindtap="onSetFontSize" data-size="large">大</view>
        <view class="size-btn {{fontSize === 'xlarge' ? 'active' : ''}}" bindtap="onSetFontSize" data-size="xlarge">超大</view>
      </view>
    </view>

    <view class="setting-item">
      <view class="setting-label">语音播报</view>
      <switch checked="{{voiceEnabled}}" bindchange="onVoiceToggle" color="#07C160"></switch>
    </view>

    <view class="setting-item">
      <view class="setting-label">当前版本</view>
      <view class="setting-value">v1.0.0</view>
    </view>

    <view class="setting-item logout-item" bindtap="onLogout">
      <view class="setting-label logout-text">退出登录</view>
    </view>
  </view>

  <!-- 修改昵称弹窗 -->
  <view class="modal-mask" wx:if="{{showNicknameModal}}">
    <view class="modal-box">
      <view class="modal-title">修改昵称</view>
      <input class="modal-input" value="{{nicknameInput}}" bindinput="onNicknameInput" placeholder="请输入新昵称" maxlength="20" focus="{{true}}" />
      <view class="modal-btns">
        <view class="modal-btn btn-cancel" bindtap="onCancelNickname">取消</view>
        <view class="modal-btn btn-confirm" bindtap="onConfirmNickname">确定</view>
      </view>
    </view>
  </view>

  <!-- 绑定验证码弹窗 -->
  <view class="modal-mask" wx:if="{{showBindCodeModal}}">
    <view class="modal-box">
      <view class="modal-title">绑定验证码</view>
      <view class="bind-code-display">{{bindCode}}</view>
      <view class="bind-code-desc">将以上 6 位验证码告知子女，{{bindCodeExpires}} 秒内有效</view>
      <view class="modal-btns">
        <view class="modal-btn btn-cancel" bindtap="onCloseBindCode">关闭</view>
        <view class="modal-btn btn-confirm" bindtap="onCopyBindCode">复制验证码</view>
      </view>
    </view>
  </view>
</view>
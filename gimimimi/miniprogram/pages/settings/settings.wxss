.page-container {
  width: 100%; height: 100vh; background: #1a1a2e; overflow: hidden;
}
.nav-bar {
  position: fixed; top: 0; left: 0; width: 100%; z-index: 100;
  background: rgba(0,0,0,0.6);
}
.nav-content {
  height: 88rpx; display: flex; align-items: center; justify-content: space-between;
  padding: 0 32rpx;
}
.nav-back { font-size: 34rpx; color: #fff; }
.nav-title { font-size: 36rpx; color: #fff; font-weight: bold; }
.nav-placeholder { width: 100rpx; }

.settings-list {
  padding-top: 140rpx; padding: 140rpx 32rpx 0;
}
.setting-item {
  display: flex; flex-direction: row; align-items: center; justify-content: space-between;
  padding: 36rpx 0;
  border-bottom: 2rpx solid rgba(255,255,255,0.1);
}
.setting-label { font-size: 34rpx; color: #fff; }
.setting-value { font-size: 30rpx; color: rgba(255,255,255,0.5); }
.setting-control { display: flex; gap: 16rpx; }
.setting-control-row { display: flex; align-items: center; gap: 12rpx; }
.setting-arrow { font-size: 40rpx; color: rgba(255,255,255,0.3); }
.size-btn {
  width: 100rpx; height: 64rpx; line-height: 64rpx; text-align: center;
  background: rgba(255,255,255,0.15); color: #fff;
  border-radius: 16rpx; font-size: 28rpx;
}
.size-btn.active { background: #07C160; }
.logout-item { border-bottom: none; margin-top: 80rpx; }
.logout-text { color: #FF3B30; }

/* 弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.6); z-index: 200;
  display: flex; align-items: center; justify-content: center;
}
.modal-box {
  width: 580rpx; background: #2a2a3e; border-radius: 24rpx;
  padding: 48rpx 40rpx 32rpx;
}
.modal-title { font-size: 36rpx; color: #fff; text-align: center; margin-bottom: 32rpx; font-weight: bold; }
.modal-input {
  width: 100%; height: 80rpx; background: rgba(255,255,255,0.1);
  border-radius: 12rpx; padding: 0 24rpx; font-size: 32rpx; color: #fff;
  box-sizing: border-box;
}
.modal-btns { display: flex; margin-top: 36rpx; gap: 24rpx; }
.modal-btn {
  flex: 1; height: 80rpx; line-height: 80rpx; text-align: center;
  border-radius: 12rpx; font-size: 30rpx;
}
.btn-cancel { background: rgba(255,255,255,0.15); color: #fff; }
.btn-confirm { background: #07C160; color: #fff; }

.bind-code-display {
  font-size: 80rpx; letter-spacing: 16rpx; color: #07C160;
  text-align: center; margin: 24rpx 0; font-weight: bold;
}
.bind-code-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); text-align: center; line-height: 1.6; }